{
  "metadata": {
    "schema_version": "5.0.0",
    "purpose": "Definir cuándo intervenir y qué pregunta seleccionar cuando una intención no está completa o requiere confirmación.",
    "language": "es-CO",
    "domain": "restaurante_colombiano_de_comida_de_mar"
  },
  "intervention_modes": {
    "needs_user_clarification": {
      "requires_clarification_compat": true,
      "description": "Falta información que debe suministrar el cliente."
    },
    "needs_transaction_confirmation": {
      "requires_clarification_compat": true,
      "description": "La solicitud está comprendida, pero debe confirmarse antes de ejecutarla."
    },
    "needs_business_lookup": {
      "requires_clarification_compat": true,
      "description": "La respuesta depende de información comercial u operativa no resuelta por NLP."
    },
    "needs_human_safety_validation": {
      "requires_clarification_compat": true,
      "description": "La respuesta requiere validación humana por seguridad alimentaria."
    },
    "needs_human_assistance": {
      "requires_clarification_compat": true,
      "description": "La solicitud está comprendida, pero necesita gestión de una persona del restaurante."
    },
    "needs_identity_verification": {
      "requires_clarification_compat": true,
      "description": "La solicitud pretende consultar o reutilizar información vinculada al cliente y exige verificar su identidad antes de continuar."
    },
    "out_of_scope": {
      "requires_clarification_compat": false,
      "description": "El mensaje no corresponde a una capacidad reconocida por el motor."
    }
  },
  "policies": {
